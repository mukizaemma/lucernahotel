# Copy relevant values into your .env. Resend: https://resend.com/docs/send-with-laravel
MAIL_MAILER=resend
RESEND_API_KEY=

MAIL_FROM_ADDRESS=info@lucernakabgayihotel.com
MAIL_FROM_NAME="Lucerna Kabgayi Hotel"

# Team notifications: primary TO + CC (e.g. Gmail for monitoring)
MAIL_NOTIFICATION_TO=info@lucernakabgayihotel.com
MAIL_NOTIFICATION_CC=hotellucernakabgayi@gmail.com

# Production: after changing any MAIL_* or RESEND_* value, run:
#   php artisan config:clear && php artisan config:cache
# Verify sending from the server:
#   php artisan mail:test your@email.com
# Resend requires the domain of MAIL_FROM_ADDRESS to be verified in the Resend dashboard.

# --- Public site: Booking.com, TripAdvisor, Google, WhatsApp (config/hotel_channels.php) ---
# Paste your full Booking.com tracking URL from the partner dashboard:
HOTEL_BOOKING_COM_URL=https://www.booking.com/hotel/rw/lucerna-kabgayi.html
HOTEL_TRIPADVISOR_LOCATION_ID=28135123
HOTEL_TRIPADVISOR_HOTEL_URL=
HOTEL_TRIPADVISOR_WRITE_REVIEW_URL=
HOTEL_GOOGLE_PLACE_URL=
HOTEL_GOOGLE_MAPS_EMBED_URL=
HOTEL_WHATSAPP_E164=250794191115
HOTEL_WHATSAPP_MESSAGE="Hello Lucerna Kabgayi Hotel, I would like to enquire about:"
HOTEL_PUBLIC_EMAIL=info@lucernakabgayihotel.com
